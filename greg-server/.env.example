# Shared secret — every data request must carry it in X-Internal-Auth.
# Must match GREG_INTERNAL_SECRET on the Cloud Run backend. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GREG_INTERNAL_SECRET=generate-a-long-random-secret

# Port Greg listens on — the Cloudflare Tunnel points at localhost:3001
PORT=3001

# Where the SQLite database lives (created on first run)
DB_PATH=./data/greg.db

# Comma-separated list of origins allowed via CORS (the Cloud Run backend's
# domain). Server-to-server requests work regardless; this only matters if
# browser requests ever hit Greg directly through the tunnel.
ALLOWED_ORIGINS=https://your-cloud-run-service.a.run.app
